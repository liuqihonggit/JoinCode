<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>JoinCode.Llm</RootNamespace>
    <AssemblyName>JoinCode.Llm</AssemblyName>
    <PackageId>JoinCode.Llm</PackageId>
    <Description>JoinCode LLM 适配器 — OpenAI/Anthropic/Azure/Pipe 查询服务</Description>
    <AllowPack>true</AllowPack>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Condition="'$(UsePackedComponents)' != 'true'" Include="$(RepoRoot)sdk\Abstractions\Abstractions.csproj" />
    <PackageReference Condition="'$(UsePackedComponents)' == 'true'" Include="JoinCode.Abstractions" Version="$(JccComponentPackageVersion)" />
    <ProjectReference Condition="'$(UsePackedComponents)' != 'true'" Include="$(RepoRoot)src\Infrastructure\Infrastructure.csproj" />
    <PackageReference Condition="'$(UsePackedComponents)' == 'true'" Include="JoinCode.Infrastructure" Version="$(JccComponentPackageVersion)" />
    <ProjectReference Condition="'$(UsePackedComponents)' != 'true'" Include="$(RepoRoot)components\08-transport\Contracts\Transport.Contracts.csproj" />
    <PackageReference Condition="'$(UsePackedComponents)' == 'true'" Include="JoinCode.Transport.Contracts" Version="$(JccComponentPackageVersion)" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Options" Version="$(MicrosoftExtensionsDependencyInjectionVersion)" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="JoinCode.Brain.Tests" />
    <InternalsVisibleTo Include="JoinCode.Infra.Tests" />
    <InternalsVisibleTo Include="JoinCode.Integration.Tests" />
    <InternalsVisibleTo Include="JoinCode.Dream.Tests" />
    <InternalsVisibleTo Include="JoinCode.Llm.Tests" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="$(RepoRoot)generators\EnumMetadata.Generator\src\EnumMetadata.Generator.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
    <ProjectReference Include="$(RepoRoot)generators\ConstructorInjection.Generator\src\ConstructorInjection.Generator.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
  </ItemGroup>

</Project>

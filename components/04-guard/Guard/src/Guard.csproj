<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>JoinCode.Guard</RootNamespace>
    <AssemblyName>JoinCode.Guard</AssemblyName>
    <PackageId>JoinCode.Guard</PackageId>
    <Description>JoinCode Guard 子系统 — 权限管理、安全护栏、Hook 系统、配置加载、OAuth 认证</Description>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="$(RepoRoot)sdk\Abstractions\Abstractions.csproj" />
    <ProjectReference Include="$(RepoRoot)src\Infrastructure\Infrastructure.csproj" />
    <ProjectReference Include="$(RepoRoot)generators\EnumMetadata.Generator\src\EnumMetadata.Generator.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
    <ProjectReference Include="$(RepoRoot)generators\ConstructorInjection.Generator\src\ConstructorInjection.Generator.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Logging" Version="$(MicrosoftExtensionsVersion)" />
    <PackageReference Include="Microsoft.Extensions.Http" Version="$(MicrosoftExtensionsVersion)" />
    <PackageReference Include="Microsoft.Extensions.Options" Version="$(MicrosoftExtensionsDependencyInjectionVersion)" />
    <PackageReference Include="TreeSitter.DotNet" Version="1.3.0" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="JoinCode.Dream.Tests" />
    <InternalsVisibleTo Include="JoinCode.Guard.Tests" />
  </ItemGroup>



  </Project>

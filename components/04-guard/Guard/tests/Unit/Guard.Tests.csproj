<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <RootNamespace>Guard.Tests</RootNamespace>
    <AssemblyName>JoinCode.Guard.Tests</AssemblyName>
    <Description>JoinCode Guard 子系统单元测试（Permission + Security + Hooks）</Description>
    <RunSettingsFilePath>$(MSBuildProjectDirectory)\.runsettings</RunSettingsFilePath>
    <NoWarn>$(NoWarn);JCC3007;JCC3010;JCC3011;JCC3012;CS0618</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="$(RepoRoot)components\04-guard\Guard\src\Guard.csproj" />
    <ProjectReference Include="$(RepoRoot)src\Infrastructure\Infrastructure.csproj" />
    <ProjectReference Include="$(RepoRoot)tests\Unit\Testing.Common\Testing.Common.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Logging.Console" Version="$(MicrosoftExtensionsVersion)" />
    <PackageReference Include="Microsoft.Extensions.TimeProvider.Testing" Version="$(MicrosoftExtensionsTimeProviderTestingVersion)" />
  </ItemGroup>

</Project>

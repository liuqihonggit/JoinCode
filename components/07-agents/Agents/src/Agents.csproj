<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>JoinCode.Agents</RootNamespace>
    <AssemblyName>JoinCode.Agents</AssemblyName>
    <PackageId>JoinCode.Agents</PackageId>
    <Description>JoinCode Agents 子系统 — Agent 协调、生命周期管理、多模型协作、Fork/Team/Swarm</Description>
    <NoWarn>$(NoWarn);IL2026;IL3050;NU5104</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="$(RepoRoot)sdk\Abstractions\Abstractions.csproj" />
    <ProjectReference Include="$(RepoRoot)src\Infrastructure\Infrastructure.csproj" />

  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="$(RepoRoot)generators\McpToolHandlers.Generator\src\McpToolHandlers.Generator.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
    <ProjectReference Include="$(RepoRoot)generators\EnumMetadata.Generator\src\EnumMetadata.Generator.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
    <ProjectReference Include="$(RepoRoot)generators\ConstructorInjection.Generator\src\ConstructorInjection.Generator.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
    <ProjectReference Include="$(RepoRoot)generators\AgentPrompt.Generator\src\AgentPrompt.Generator.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Logging" Version="$(MicrosoftExtensionsVersion)" />
    <PackageReference Include="Microsoft.Extensions.Configuration" Version="$(MicrosoftExtensionsVersion)" />
    <PackageReference Include="Microsoft.Extensions.Caching.Memory" Version="$(MicrosoftExtensionsVersion)" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="JoinCode.Agents.Tests" />
    <InternalsVisibleTo Include="JoinCode.Composition" />
    <InternalsVisibleTo Include="JoinCode.Composition.Tests" />
  </ItemGroup>

</Project>
